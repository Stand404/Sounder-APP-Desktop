    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- 全局字体：按平台选择原生最佳中文字体
             Win → 微软雅黑，macOS → 苹方，Linux → 系统默认 sans-serif
             FontFamily 是 TextElement 的附加属性，设置到 Control 即可对全局生效。 -->
        <Style Selector="Control">
            <Setter Property="TextElement.FontFamily" Value="Microsoft YaHei, PingFang SC, sans-serif" />
        </Style>

        <!-- 全局样式引入 -->
        <StyleInclude Source="/Views/Common/Templates/ButtonStyles.axaml"/>
        <StyleInclude Source="/Views/Common/Templates/InputStyles.axaml"/>
    </Application.Styles>
</Application>
