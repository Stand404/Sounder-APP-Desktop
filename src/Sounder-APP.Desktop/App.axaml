<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Sounder_APP.App"
             xmlns:local="using:Sounder_APP"
             xmlns:converters="using:Sounder_APP.Converters"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- ============================================================
                     亮色主题 — 三层视觉深度
                     冷调灰 + 靛蓝强调色，干净清爽的现代 APP 风格
                     ============================================================ -->
                <ResourceDictionary x:Key="Light">
                    <!-- 三层背景：Lv1(页面底) → Lv2(区块/面板) → Lv3(卡片/弹窗) -->
                    <SolidColorBrush x:Key="Lv1Bg" Color="#F5F6FA"/>
                    <SolidColorBrush x:Key="Lv2Bg" Color="#FAFBFC"/>
                    <SolidColorBrush x:Key="Lv2Border" Color="#E2E5EB"/>
                    <SolidColorBrush x:Key="Lv2Hover" Color="#EEF1F7"/>
                    <SolidColorBrush x:Key="Lv3Bg" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="Lv3Border" Color="#E8EBF0"/>

                    <!-- 文本色：深蓝灰→中灰→浅灰，提升可读性 -->
                    <SolidColorBrush x:Key="TextPrimary" Color="#1D1F27"/>
                    <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
                    <SolidColorBrush x:Key="TextTertiary" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="LabelText" Color="#82858F"/>

                    <!-- 强调色：与暗色主题一致的天空蓝 -->
                    <SolidColorBrush x:Key="AccentBlue" Color="#5DA3E8"/>
                    <SolidColorBrush x:Key="AccentBlueHover" Color="#4A8AD0"/>
                    <SolidColorBrush x:Key="AccentBluePressed" Color="#7DBAF0"/>

                    <!-- 按钮文字（深色按钮上的白色文字） -->
                    <SolidColorBrush x:Key="BtnFgSoft" Color="#FFFFFF"/>

                    <!-- 选中态：中性灰底色 -->
                    <SolidColorBrush x:Key="SelectBg" Color="#F0F0F3"/>

                    <!-- 顶部提示条背景（浅主题色） -->
                    <SolidColorBrush x:Key="TipBg" Color="#E5EFF9"/>

                    <!-- 播放中高亮背景（AccentBlue 8% 透明） -->
                    <SolidColorBrush x:Key="PlayingHighlightBg" Color="#145DA3E8"/>

                    <!-- 状态色：已安装/未安装/错误 -->
                    <SolidColorBrush x:Key="StatusInstalled" Color="#ECFDF5"/>
                    <SolidColorBrush x:Key="StatusInstalledText" Color="#059669"/>
                    <SolidColorBrush x:Key="StatusNotInstalled" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="StatusNotInstalledText" Color="#8B8F98"/>
                    <SolidColorBrush x:Key="ErrorRed" Color="#EF4444"/>
                    <SolidColorBrush x:Key="ErrorRedHover" Color="#DC2626"/>
                    <SolidColorBrush x:Key="ErrorRedPressed" Color="#F87171"/>

                    <!-- 侧边栏 / 标题栏 -->
                    <SolidColorBrush x:Key="SidebarBg" Color="#F8F9FC"/>
                    <SolidColorBrush x:Key="SidebarIconActive" Color="#4B4F5C"/>
                    <SolidColorBrush x:Key="SidebarIconInactive" Color="Transparent"/>
                    <SolidColorBrush x:Key="TitleBarBtnFg" Color="#4B4F5C"/>
                    <SolidColorBrush x:Key="TitleBarBtnHoverBg" Color="#0A000000"/>
                    <SolidColorBrush x:Key="NavBtnHoverBg" Color="#08000000"/>
                </ResourceDictionary>

                <!-- ============================================================
                     暗色主题 — 三层视觉深度
                     ============================================================ -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="Lv1Bg" Color="#0D0D0D"/>
                    <SolidColorBrush x:Key="Lv2Bg" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="Lv2Border" Color="#2A2A2A"/>
                    <SolidColorBrush x:Key="Lv2Hover" Color="#202020"/>
                    <SolidColorBrush x:Key="Lv3Bg" Color="#212121"/>
                    <SolidColorBrush x:Key="Lv3Border" Color="#333333"/>

                    <!-- 文本色 -->
                    <SolidColorBrush x:Key="TextPrimary" Color="#E6E6E6"/>
                    <SolidColorBrush x:Key="TextSecondary" Color="#8E8E8E"/>
                    <SolidColorBrush x:Key="TextTertiary" Color="#5E5E5E"/>
                    <SolidColorBrush x:Key="LabelText" Color="#767676"/>

                    <!-- 强调色 -->
                    <SolidColorBrush x:Key="AccentBlue" Color="#5DA3E8"/>
                    <SolidColorBrush x:Key="AccentBlueHover" Color="#4A8AD0"/>
                    <SolidColorBrush x:Key="AccentBluePressed" Color="#7DBAF0"/>

                    <!-- 按钮文字（浅底色上的柔白） -->
                    <SolidColorBrush x:Key="BtnFgSoft" Color="#E0E0E0"/>

                    <!-- 选中态 -->
                    <SolidColorBrush x:Key="SelectBg" Color="#2A2A2A"/>

                    <!-- 顶部提示条背景（浅主题色） -->
                    <SolidColorBrush x:Key="TipBg" Color="#1A2430"/>

                    <!-- 播放中高亮背景（AccentBlue 16% 透明，暗底需更明显） -->
                    <SolidColorBrush x:Key="PlayingHighlightBg" Color="#285DA3E8"/>

                    <!-- 状态色 -->
                    <SolidColorBrush x:Key="StatusInstalled" Color="#1A3422"/>
                    <SolidColorBrush x:Key="StatusInstalledText" Color="#5CB860"/>
                    <SolidColorBrush x:Key="StatusNotInstalled" Color="#242424"/>
                    <SolidColorBrush x:Key="StatusNotInstalledText" Color="#7A7A7A"/>
                    <SolidColorBrush x:Key="ErrorRed" Color="#EF5350"/>
                    <SolidColorBrush x:Key="ErrorRedHover" Color="#E53935"/>
                    <SolidColorBrush x:Key="ErrorRedPressed" Color="#F27774"/>

                    <!-- 侧边栏 / 标题栏 -->
                    <SolidColorBrush x:Key="SidebarBg" Color="#0A0A0A"/>
                    <SolidColorBrush x:Key="SidebarIconActive" Color="#9E9E9E"/>
                    <SolidColorBrush x:Key="SidebarIconInactive" Color="Transparent"/>
                    <SolidColorBrush x:Key="TitleBarBtnFg" Color="#666666"/>
                    <SolidColorBrush x:Key="TitleBarBtnHoverBg" Color="#30FFFFFF"/>
                    <SolidColorBrush x:Key="NavBtnHoverBg" Color="#18FFFFFF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>

        <!-- 转换器 -->
        <converters:PlayModeToIndexConverter x:Key="PlayModeToIndex"/>
        <converters:OrderModeToIndexConverter x:Key="OrderModeToIndex"/>
        <converters:BoolToValueConverter x:Key="BoolToValue"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:NullToBoolConverter x:Key="IsNotNull"/>
        <converters:InverseNullToBoolConverter x:Key="IsNull"/>
        <converters:StringEqualsConverter x:Key="StringEquals"/>
        <converters:StringNotEqualsConverter x:Key="StringNotEquals"/>
        <converters:StringEqualMultiConverter x:Key="StringEqualMulti"/>
        <converters:StringNotEqualMultiConverter x:Key="StringNotEqualMulti"/>
        <converters:PlayingBackgroundMultiConverter x:Key="PlayingBackground"/>
        <converters:PlayingForegroundMultiConverter x:Key="PlayingForeground"/>
        <converters:BoolToDoubleConverter x:Key="BoolToDouble"/>
        <converters:BoolToOffsetConverter x:Key="BoolToOffset"/>
        <converters:SetContainsMultiConverter x:Key="SetContainsMulti"/>
        <converters:SetNotContainsMultiConverter x:Key="SetNotContainsMulti"/>
        <converters:PlayingBackgroundSetConverter x:Key="PlayingBackgroundSet"/>
        <converters:BoolToThicknessConverter x:Key="BoolToThickness"/>
        <converters:FloatToPercentConverter x:Key="FloatToPercent"/>
        <converters:HexToBrushConverter x:Key="HexToBrush"/>
        <converters:FloatToBoolConverter x:Key="FloatToBool"/>


