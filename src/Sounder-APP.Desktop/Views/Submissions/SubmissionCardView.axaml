<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:Sounder_APP.Models"
             xmlns:i18n="clr-namespace:Sounder_APP.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="200"
             x:Class="Sounder_APP.Views.Submissions.SubmissionCardView"
             x:DataType="models:Submission">

    <Design.DataContext>
        <models:Submission ResourceName="示例资源包"
                           AppName="SampleApp"
                           Nickname="投稿者"
                           Platform="哔哩"
                           Brief="这是一个示例资源包简述"
                           ImageSource="游戏截图"
                           VoiceSource="游戏录制"
                           CreatedAt="2025-01-01"
                           Status="InProgress"/>
    </Design.DataContext>

    <Border CornerRadius="12" Background="{DynamicResource Lv2Bg}" Padding="0">
        <DockPanel>
            <!-- 左侧状态色条 -->
            <Border DockPanel.Dock="Left" Width="6"
                    Background="{Binding StatusSideColor, Converter={StaticResource HexToBrush}}"
                    CornerRadius="6,0,0,6"/>

            <!-- 卡片主体内容 -->
            <Grid RowDefinitions="Auto,Auto">
                <!-- ===== 头部（可点击展开/折叠） ===== -->
                <Border Grid.Row="0" Padding="20,16" Cursor="Hand"
                        Background="Transparent"
                        Tapped="OnHeaderTapped">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <!-- 资源名称 -->
                            <TextBlock Text="{Binding ResourceName}" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- 元信息行 -->
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="{StaticResource IconTag}" Width="13" Height="13"
                                              Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding AppName}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="13" Height="13"
                                              Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Nickname}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="{StaticResource IconSchedule}" Width="13" Height="13"
                                              Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- 平台标签 -->
                                <Border CornerRadius="4" Padding="6,1"
                                        Background="{DynamicResource Lv3Bg}">
                                    <TextBlock Text="{Binding PlatformDisplay}" FontSize="11"
                                               Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- 展开/折叠箭头 -->
                        <PathIcon Grid.Column="1" Data="{StaticResource IconMore}"
                                  Width="18" Height="18"
                                  Foreground="{DynamicResource TextTertiary}"
                                  VerticalAlignment="Center"
                                  x:Name="ExpandArrow"/>
                    </Grid>
                </Border>

                <!-- ===== 展开详情 ===== -->
                <Border Grid.Row="1" x:Name="DetailPanel"
                        BorderBrush="{DynamicResource Lv2Border}" BorderThickness="0,1,0,0"
                        IsVisible="False"
                        Padding="20,16">
                    <StackPanel Spacing="14">
                        <!-- 简述 -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="{i18n:Translate card_brief_label}" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding Brief}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- 来源信息 -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{i18n:Translate card_image_source}" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextTertiary}"/>
                                <TextBlock Text="{Binding ImageSource}" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{i18n:Translate card_voice_source}" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextTertiary}"/>
                                <TextBlock Text="{Binding VoiceSource}" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 图片来源链接 -->
                        <StackPanel Spacing="4" IsVisible="{Binding HasImageSourceLink}">
                            <TextBlock Text="{i18n:Translate card_image_source_link}" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextTertiary}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding ImageSourceLink}" FontSize="13"
                                           Foreground="{DynamicResource AccentBlue}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                <Button Tag="{Binding ImageSourceLink}"
                                        Background="Transparent" BorderThickness="0" Padding="0"
                                        Cursor="Hand" Tapped="OnCopyTapped"
                                        ToolTip.Tip="{i18n:Translate copy_link}" VerticalAlignment="Center" MinWidth="18" MinHeight="18">
                                    <PathIcon Data="{StaticResource IconClone}" Width="14" Height="14"
                                              Foreground="{DynamicResource TextTertiary}"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- 声音来源链接 -->
                        <StackPanel Spacing="4" IsVisible="{Binding HasVoiceSourceLink}">
                            <TextBlock Text="{i18n:Translate card_voice_source_link}" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextTertiary}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding VoiceSourceLink}" FontSize="13"
                                           Foreground="{DynamicResource AccentBlue}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                <Button Tag="{Binding VoiceSourceLink}"
                                        Background="Transparent" BorderThickness="0" Padding="0"
                                        Cursor="Hand" Tapped="OnCopyTapped"
                                        ToolTip.Tip="{i18n:Translate copy_link}" VerticalAlignment="Center" MinWidth="18" MinHeight="18">
                                    <PathIcon Data="{StaticResource IconClone}" Width="14" Height="14"
                                              Foreground="{DynamicResource TextTertiary}"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- 备注 -->
                        <StackPanel Spacing="4" IsVisible="{Binding HasFileLink}">
                            <TextBlock Text="{i18n:Translate card_note}" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextTertiary}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding FileLink}" FontSize="13"
                                           Foreground="{DynamicResource AccentBlue}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                <Button Tag="{Binding FileLink}"
                                        Background="Transparent" BorderThickness="0" Padding="0"
                                        Cursor="Hand" Tapped="OnCopyTapped"
                                        ToolTip.Tip="{i18n:Translate copy_link}" VerticalAlignment="Center" MinWidth="18" MinHeight="18">
                                    <PathIcon Data="{StaticResource IconClone}" Width="14" Height="14"
                                              Foreground="{DynamicResource TextTertiary}"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- 平台账号 -->
                        <StackPanel Spacing="4" IsVisible="{Binding HasPlatformId}">
                            <TextBlock Text="{i18n:Translate card_platform_id}" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding PlatformId}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
