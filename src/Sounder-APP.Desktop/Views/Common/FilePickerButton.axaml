<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Sounder_APP.Views.Common.FilePickerButton"
             x:Name="Root">

    <Button Command="{Binding Command, ElementName=Root}"
            Classes="btn primary"
            HorizontalContentAlignment="Center"
            HorizontalAlignment="Stretch"
            Margin="14"
            Padding="12,10">
        <StackPanel Orientation="Horizontal" Spacing="6"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <PathIcon Data="{StaticResource IconFolder}" Width="14" Height="14"
                      VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Text, ElementName=Root}" VerticalAlignment="Center"/>
        </StackPanel>
    </Button>

</UserControl>
