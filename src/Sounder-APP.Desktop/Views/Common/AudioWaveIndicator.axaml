<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Sounder_APP.Views.AudioWaveIndicator"
             Width="28" Height="28">

    <StackPanel Orientation="Horizontal" Spacing="4"
                HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Width="4" CornerRadius="2"
                Background="{DynamicResource AccentBlue}"
                VerticalAlignment="Bottom"
                RenderTransformOrigin="50%,100%"
                Classes="wave-bar wave-bar-0"/>
        <Border Width="4" CornerRadius="2"
                Background="{DynamicResource AccentBlue}"
                VerticalAlignment="Bottom"
                RenderTransformOrigin="50%,100%"
                Classes="wave-bar wave-bar-1"/>
        <Border Width="4" CornerRadius="2"
                Background="{DynamicResource AccentBlue}"
                VerticalAlignment="Bottom"
                RenderTransformOrigin="50%,100%"
                Classes="wave-bar wave-bar-2"/>
        <Border Width="4" CornerRadius="2"
                Background="{DynamicResource AccentBlue}"
                VerticalAlignment="Bottom"
                RenderTransformOrigin="50%,100%"
                Classes="wave-bar wave-bar-3"/>
    </StackPanel>

    <UserControl.Styles>
        <Style Selector="Border.wave-bar">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleY="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Border.wave-bar-0">
            <Setter Property="Height" Value="8"/>
            <Style.Animations>
                <Animation Duration="0:0:0.8" Delay="0:0:0.00"
                           IterationCount="Infinite" PlaybackDirection="Alternate"
                           FillMode="Both">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleY" Value="0.4"/>
                        <Setter Property="Opacity" Value="0.5"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.wave-bar-1">
            <Setter Property="Height" Value="14"/>
            <Style.Animations>
                <Animation Duration="0:0:0.8" Delay="0:0:0.20"
                           IterationCount="Infinite" PlaybackDirection="Alternate"
                           FillMode="Both">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleY" Value="0.4"/>
                        <Setter Property="Opacity" Value="0.5"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.wave-bar-2">
            <Setter Property="Height" Value="10"/>
            <Style.Animations>
                <Animation Duration="0:0:0.8" Delay="0:0:0.40"
                           IterationCount="Infinite" PlaybackDirection="Alternate"
                           FillMode="Both">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleY" Value="0.4"/>
                        <Setter Property="Opacity" Value="0.5"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.wave-bar-3">
            <Setter Property="Height" Value="18"/>
            <Style.Animations>
                <Animation Duration="0:0:0.8" Delay="0:0:0.60"
                           IterationCount="Infinite" PlaybackDirection="Alternate"
                           FillMode="Both">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleY" Value="0.4"/>
                        <Setter Property="Opacity" Value="0.5"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
</UserControl>
