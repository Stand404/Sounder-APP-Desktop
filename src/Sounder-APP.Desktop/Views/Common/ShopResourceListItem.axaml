<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ibtn="clr-namespace:Sounder_APP.Views.InstallButton"
             mc:Ignorable="d" d:DesignWidth="340" d:DesignHeight="72"
             x:Class="Sounder_APP.Views.Common.ShopResourceListItem"
             x:Name="Root"
             x:CompileBindings="False">

    <Border CornerRadius="12" Padding="12,10" BorderThickness="0"
            Background="Transparent">
        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
            <!-- 图标 -->
            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12"
                    Background="{DynamicResource Lv2Border}" ClipToBounds="True"
                    VerticalAlignment="Center">
                <Grid>
                    <PathIcon Data="{StaticResource IconSpinner}" Width="22" Height="22"
                              Foreground="{DynamicResource TextTertiary}" Opacity="0.7"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Classes="spinner"
                              IsVisible="{Binding IconLoadFailed, Converter={StaticResource InverseBool}}"/>
                    <PathIcon Data="{StaticResource IconBroken}" Width="22" Height="22"
                              Foreground="{DynamicResource AccentBlue}" Opacity="0.6"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              IsVisible="{Binding IconLoadFailed}"/>
                    <Image Source="{Binding IconBitmap}"
                           Stretch="UniformToFill"
                           IsVisible="{Binding IconBitmap, Converter={StaticResource IsNotNull}}"/>
                </Grid>
            </Border>

            <!-- 信息 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Description}" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis" MaxLines="2"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding SizeFormatted}" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                </StackPanel>
            </StackPanel>

            <!-- 安装按钮 / 已安装 -->
<ibtn:CompactInstallButton Grid.Column="2"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding IsInstalled, Converter={StaticResource InverseBool}}"
                                        Command="{Binding ViewModel.InstallResourceCommand, ElementName=Root}"
                                        CommandParameter="{Binding Resource, ElementName=Root}"
                                        InstallingResourceId="{Binding ActiveInstallingId}"
                                        ResourceId="{Binding Id}"
                                        InstallProgress="{Binding DownloadProgress}"
                                        InstallStatusText="{Binding DownloadStatusText}"
                                        IsPaused="{Binding IsDownloadPaused}"/>

            <Border Grid.Column="2" Width="76" Height="32" VerticalAlignment="Center"
                    IsVisible="{Binding IsInstalled}">
                <PathIcon Data="{StaticResource IconCheck}"
                         Width="16" Height="16"
                         Foreground="{DynamicResource StatusInstalledText}"
                         VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>

    <UserControl.Styles>
        <Style Selector="PathIcon.spinner">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0"/>
                </Setter.Value>
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
</UserControl>
