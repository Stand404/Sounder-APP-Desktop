<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Sounder_APP.Views.Common"
             x:Class="Sounder_APP.Views.Common.Drawer"
             x:DataType="views:Drawer">

    <!-- 默认隐藏整个 Drawer，通过 IsOpen 控制显示/动画 -->
    <Panel x:Name="PART_RootPanel">
        <!-- ===== 半透明遮罩层（点击可关闭） ===== -->
        <Border x:Name="PART_Backdrop"
                Background="#80000000"
                Opacity="0"
                IsHitTestVisible="False"
                ZIndex="90"
                Tapped="OnBackdropTapped"/>

        <!-- ===== 右侧抽屉面板 ===== -->
        <Border x:Name="PART_DrawerPanel"
                Width="{Binding DrawerWidth, RelativeSource={RelativeSource AncestorType=views:Drawer}}"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{DynamicResource Lv2Bg}"
                ClipToBounds="True"
                IsVisible="False"
                IsHitTestVisible="False"
                ZIndex="100">

            <Grid RowDefinitions="Auto,*,Auto">
                <!-- ===== 标题栏 ===== -->
                <Border Grid.Row="0"
                        Padding="12"
                        BorderBrush="{DynamicResource Lv2Border}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="PART_TitleBlock"
                                   Text="{Binding Title, RelativeSource={RelativeSource AncestorType=views:Drawer}}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1"
                                Content="✕"
                                FontSize="14"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource TextTertiary}"
                                Cursor="Hand"
                                Padding="8,4"
                                Tapped="OnCloseTapped"/>
                    </Grid>
                </Border>

                <!-- ===== 内容区域 ===== -->
                <ContentPresenter Grid.Row="1"
                                  x:Name="PART_ContentPresenter"
                                  Content="{Binding DrawerContent, RelativeSource={RelativeSource AncestorType=views:Drawer}}"/>

                <!-- ===== 底部操作栏 ===== -->
                <Border Grid.Row="2"
                        Padding="12"
                        BorderBrush="{DynamicResource Lv2Border}"
                        BorderThickness="0,1,0,0"
                        IsVisible="{Binding ShowFooter, RelativeSource={RelativeSource AncestorType=views:Drawer}}">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                        <!-- 左侧提示信息 -->
                        <TextBlock Grid.Column="0"
                                   x:Name="PART_FooterHint"
                                   Text="{Binding FooterHint, RelativeSource={RelativeSource AncestorType=views:Drawer}}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextTertiary}"
                                   VerticalAlignment="Center"
                                   IsVisible="False"/>

                        <!-- 取消按钮 -->
                        <Button Grid.Column="1"
                                x:Name="PART_CancelBtn"
                                Classes="btn secondary"
                                MinWidth="80"
                                Padding="16,8"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="False"
                                Tapped="OnCancelTapped">
                            <TextBlock Text="{Binding CancelText, RelativeSource={RelativeSource AncestorType=views:Drawer}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>

                        <!-- 确认按钮 -->
                        <Button Grid.Column="2"
                                x:Name="PART_ConfirmBtn"
                                Classes="btn primary"
                                MinWidth="80"
                                Padding="16,8"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                VerticalAlignment="Center"
                                Tapped="OnConfirmTapped">
                            <TextBlock Text="{Binding ConfirmText, RelativeSource={RelativeSource AncestorType=views:Drawer}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>

</UserControl>
