<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sounder_APP.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="340" d:DesignHeight="750"
             x:Class="Sounder_APP.Views.ResourceListSkeleton"
             x:DataType="vm:ShopViewModel">

    <Design.DataContext>
        <vm:ShopViewModel/>
    </Design.DataContext>

    <ScrollViewer Margin="8,0,8,8">
        <StackPanel Spacing="4">
            <!-- 骨架项 × 8，所有文字骨架块左对齐，大小匹配实际列表项 -->
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
            <Border Classes="skeleton" CornerRadius="12" Padding="12,10" Background="{DynamicResource Lv2Bg}">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12" Background="{DynamicResource Lv2Border}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <Border Height="14" Width="100" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="12" Width="140" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                        <Border Height="11" Width="50" CornerRadius="4" Background="{DynamicResource Lv2Border}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="80" Height="32" CornerRadius="16" Background="{DynamicResource Lv2Border}"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <UserControl.Styles>
        <Style Selector="Border.skeleton">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.9"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.4"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.9"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="PathIcon.spinner">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0"/>
                </Setter.Value>
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
</UserControl>
