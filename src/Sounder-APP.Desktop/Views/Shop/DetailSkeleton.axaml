<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sounder_APP.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="710" d:DesignHeight="750"
             x:Class="Sounder_APP.Views.DetailSkeleton"
             x:DataType="vm:ShopViewModel">

    <Design.DataContext>
        <vm:ShopViewModel/>
    </Design.DataContext>

    <Grid>
        <!-- 初始加载骨架屏（IsLoading，列表还在加载时用简单骨架） -->
        <ScrollViewer Background="{DynamicResource Lv1Bg}"
                      IsVisible="{Binding IsLoading}">
            <Border Classes="skeleton" Padding="24,20" Background="{DynamicResource Lv2Bg}">
                <StackPanel Spacing="16">
                    <Border CornerRadius="16" Width="70" Height="70" Background="{DynamicResource Lv2Border}"/>
                    <Border CornerRadius="4" Height="18" Width="180" Background="{DynamicResource Lv2Border}"
                            HorizontalAlignment="Left"/>
                    <Border CornerRadius="4" Height="13" Width="280" Background="{DynamicResource Lv2Border}"
                            HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                        <Border CornerRadius="20" Width="72" Height="22" Background="{DynamicResource Lv2Border}"/>
                        <Border CornerRadius="20" Width="90" Height="22" Background="{DynamicResource Lv2Border}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- 详情骨架屏（IsDetailLoading，切换资源时显示，匹配 Kotlin 版结构） -->
        <ScrollViewer Background="{DynamicResource Lv1Bg}"
                      IsVisible="{Binding IsDetailLoading}">
            <StackPanel Spacing="0">

                <!-- ===== Header 骨架 ===== -->
                <Border Classes="skeleton" Padding="24,20" Background="{DynamicResource Lv2Bg}">
                    <Grid ColumnDefinitions="70,*" ColumnSpacing="16">
                        <!-- 图标 70x70 -->
                        <Border Grid.Column="0" Width="70" Height="70" CornerRadius="16"
                                Background="{DynamicResource Lv2Border}"/>
                        <!-- 名称 + 描述 + Pill（靠左对齐） -->
                        <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Top">
                            <!-- 标题（fillMaxWidth 0.5f ≈ 180px） -->
                            <Border Height="18" Width="180" CornerRadius="4"
                                    Background="{DynamicResource Lv2Border}"
                                    HorizontalAlignment="Left" Margin="0,2,0,8"/>
                            <!-- 描述（fillMaxWidth 0.7f ≈ 280px） -->
                            <Border Height="13" Width="280" CornerRadius="4"
                                    Background="{DynamicResource Lv2Border}"
                                    HorizontalAlignment="Left" Margin="0,0,0,6"/>
                            <!-- 大小/日期 Pill -->
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                <Border CornerRadius="20" Width="72" Height="22"
                                        Background="{DynamicResource Lv2Border}"/>
                                <Border CornerRadius="20" Width="90" Height="22"
                                        Background="{DynamicResource Lv2Border}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== 音频列表区域骨架 ===== -->
                <Border Classes="skeleton" Padding="16,20">
                    <StackPanel Spacing="0">

                        <!-- 标题行：在线试听 + PillToggle -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                            <Border Grid.Column="0" Width="140" Height="16" CornerRadius="4"
                                    Background="{DynamicResource Lv2Border}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Width="100" Height="28" CornerRadius="14"
                                    Background="{DynamicResource Lv2Border}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 音频列表项 × 6（使用 Lv2Border，仅左侧名称+时长） -->
                        <Border Padding="12,10" Background="Transparent">
                            <StackPanel Spacing="6">
                                <Border Height="15" Width="160" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                                <Border Height="12" Width="60" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Height="0.5" Background="{DynamicResource Lv2Border}" Opacity="0.5" Margin="4,0"/>
                        <Border Padding="12,10" Background="Transparent">
                            <StackPanel Spacing="6">
                                <Border Height="15" Width="160" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                                <Border Height="12" Width="60" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Height="0.5" Background="{DynamicResource Lv2Border}" Opacity="0.5" Margin="4,0"/>
                        <Border Padding="12,10" Background="Transparent">
                            <StackPanel Spacing="6">
                                <Border Height="15" Width="160" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                                <Border Height="12" Width="60" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Height="0.5" Background="{DynamicResource Lv2Border}" Opacity="0.5" Margin="4,0"/>
                        <Border Padding="12,10" Background="Transparent">
                            <StackPanel Spacing="6">
                                <Border Height="15" Width="160" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                                <Border Height="12" Width="60" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Height="0.5" Background="{DynamicResource Lv2Border}" Opacity="0.5" Margin="4,0"/>
                        <Border Padding="12,10" Background="Transparent">
                            <StackPanel Spacing="6">
                                <Border Height="15" Width="160" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                                <Border Height="12" Width="60" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Height="0.5" Background="{DynamicResource Lv2Border}" Opacity="0.5" Margin="4,0"/>
                        <Border Padding="12,10" Background="Transparent">
                            <StackPanel Spacing="6">
                                <Border Height="15" Width="160" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                                <Border Height="12" Width="60" CornerRadius="4"
                                        Background="{DynamicResource Lv2Border}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Border.skeleton">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.9"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.4"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.9"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>
</UserControl>
