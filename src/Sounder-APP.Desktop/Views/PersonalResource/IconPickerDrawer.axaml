<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sounder_APP.ViewModels"
             xmlns:common="using:Sounder_APP.Views.Common"
             xmlns:models="using:Sounder_APP.Models"
             xmlns:i18n="clr-namespace:Sounder_APP.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Sounder_APP.Views.IconPickerDrawer"
             x:DataType="vm:PersonalResourceEditViewModel">

    <common:Drawer IsOpen="{Binding IsIconPickerVisible}"
                   Title="{i18n:Translate select_icon}"
                   DrawerWidth="380"
                   ConfirmText="{i18n:Translate choose}"
                   CancelText="{i18n:Translate cancel}"
                   Confirmed="OnConfirmed"
                   Cancelled="OnCancelled"
                   Closed="OnCancelled">
        <common:Drawer.DrawerContent>
            <Grid RowDefinitions="Auto,Auto,Auto,*">
                <!-- 从文件选择 -->
                <common:FilePickerButton Grid.Row="0"
                                        Command="{Binding PickIconFromFileCommand}"/>
                <TextBlock Grid.Row="2" Text="{i18n:Translate pick_icon_in_app}" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="14,2,14,10"/>
                <!-- 图标网格（可滚动） -->
                <ScrollViewer Grid.Row="3" Margin="8,0,8,12">
                    <ItemsControl ItemsSource="{Binding PickerIconItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:PickerIconItem">
                                <Border Width="64" Height="64" CornerRadius="12"
                                        Background="{DynamicResource Lv3Bg}"
                                        Cursor="Hand"
                                        ClipToBounds="True"
                                        Margin="4"
                                        Tapped="OnIconItemTapped"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Image Source="{Binding IconBitmap}" Stretch="UniformToFill"/>
                                        <Border IsVisible="{Binding IsSelected}"
                                                CornerRadius="6"
                                                Background="{DynamicResource AccentBlue}"
                                                Width="22" Height="22"
                                                Margin="5"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                            <TextBlock Text="✓" FontSize="11" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </common:Drawer.DrawerContent>
    </common:Drawer>

</UserControl>
